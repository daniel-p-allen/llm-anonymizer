# --- Generated at runtime -------------------------------------------------
# These are produced by the tool and may contain real personal data.
# Never commit them.
data.json
anonymized_data.json
swapped.json
output_data.csv
finished_data.csv

# --- Credentials ----------------------------------------------------------
# secret.json  = Google OAuth client secret (from Google Cloud Console)
# token.json   = cached user access/refresh token, written on first auth
secret.json
token.json
credentials.json
client_secret*.json
token.pickle
*.pem
.env

# --- Python ---------------------------------------------------------------
.venv/
__pycache__/
*.pyc

# --- Build artifacts ------------------------------------------------------
# `anonymizer` is the compiled binary produced by the Makefile. It shares its
# name with the project, so it is easy to commit by accident.
anonymizer
app
appce
*.o
*.out
*.dSYM/
build/

# --- Logs -----------------------------------------------------------------
logs/
*.log

# --- Editor / OS ----------------------------------------------------------
# c_cpp_properties.json is kept so IntelliSense can find the SplashKit headers.
# The browse database is a multi-megabyte local cache and must not be committed.
.vscode/*
!.vscode/c_cpp_properties.json
.DS_Store

# --- Working notes (not for the public repo) ------------------------------
HANDOFF.md
